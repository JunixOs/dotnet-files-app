@page
@using Web_App.Models
@model ViewFilmPageModel

<!DOCTYPE html>
<html>
    <head>
        <title>Films App - Ver Pelicula</title>
    
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    </head>
    <style>
        .actor-card {
            transition: all 0.2s ease-in-out;
            border-radius: 15px;
        }

        .actor-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

        .card {
            border-radius: 20px;
        }
    </style>
    <body class="bg-light">
        <div class="container mt-5">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- Header -->
                <div class="bg-dark text-white p-4">
                    <h2 class="mb-1">@Model.FilmModel.Name</h2>
                    <small class="text-light">
                        Estreno: @Model.FilmModel.PremierDate.ToString("yyyy-MM-dd")
                    </small>
                </div>

                <!-- Contenido -->
                <div class="card-body">

                    <!-- Información general -->
                    <div class="mb-4">
                        <h5 class="fw-bold">Información general</h5>
                        <hr />
                        <p><strong>ID:</strong> @Model.FilmModel.Id</p>
                    </div>

                    <!-- Actores -->
                    <div>
                        <h5 class="fw-bold mb-3">Actores</h5>

                        <div class="row g-3">
                            @foreach (var actor in Model.FilmModel.ActorModels ?? new List<ActorModel>())
                            {
                                <div class="col-md-6 col-lg-4">
                                    <div class="card actor-card border-0 shadow-sm h-100">
                                        <div class="card-body">

                                            <h6 class="fw-bold mb-1">
                                                @actor.FirstName @actor.LastName
                                            </h6>

                                            <small class="text-muted">
                                                @actor.BirthDay.ToString("yyyy-MM-dd")
                                            </small>

                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (!(Model.FilmModel.ActorModels?.Any() ?? false))
                        {
                            <p class="text-muted mt-2">No hay actores registrados</p>
                        }
                    </div>

                </div>

                <!-- Footer -->
                <div class="card-footer bg-white border-0 d-flex justify-content-between">

                    <a asp-page="/Films/Index" class="btn btn-outline-secondary">
                        Volver
                    </a>

                    <div>
                        <a asp-page="/Films/EditFilm" asp-route-id="@Model.FilmModel.Id" 
                        class="btn btn-outline-warning me-2">
                            Editar
                        </a>

                        <a asp-page="/Films/DeleteFilm" asp-route-id="@Model.FilmModel.Id" 
                        class="btn btn-outline-danger">
                            Eliminar
                        </a>
                    </div>

                </div>

            </div>

        </div>
    </body>
</html>