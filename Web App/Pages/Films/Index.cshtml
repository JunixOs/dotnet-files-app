@page
@model FilmIndexPageModel

<!DOCTYPE html>
<html>
    <head>
        <title>Films App - Films</title>
    
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    </head>
    <body class="bg-light">
        <div class="container mt-5">
            <h2 class="mb-4 text-center">Listado de Películas</h2>

            @if(!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger text-center">
                    @Model.ErrorMessage
                </div>
            }
            else if(Model.FilmModels is null || Model.FilmModels.Count == 0)
            {
                <div class="alert alert-info" role="alert">
                    No se encontraron peliculas para mostrar
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0">Listado de Películas</h5>

                            <a asp-page="/Films/SaveFilm" class="btn btn-success">
                                + Añadir Película
                            </a>
                        </div>

                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>ID</th>
                                    <th>Título</th>
                                    <th>Fecha de Estreno</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var movie in Model.FilmModels ?? new List<Models.FilmModel>())
                                {
                                    <tr>
                                        <td>@movie.Id</td>
                                        <td>@movie.Name</td>
                                        <td>@movie.PremierDate</td>
                                        <td>
                                            <a asp-page="/Films/ViewFilm" asp-route-id="@movie.Id" class="btn btn-primary">Ver</a>
                                            <a asp-page="/Films/EditFilm" asp-route-id="@movie.Id" class="btn btn-info">Editar</a>
                                            <a asp-page="/Films/DeleteFilm" asp-route-id="@movie.Id" class="btn btn-danger">Eliminar</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                    </div>
                </div>
            }
        </div>
    </body>
</html>